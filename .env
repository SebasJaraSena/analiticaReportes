# ── Control DB (propio PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=reportes
POSTGRES_PASSWORD=reportes_2026_secret
POSTGRES_DB=reportes

DATABASE_HOST=host.docker.internal
DATABASE_PORT=5432
DATABASE_DB=reportes
DATABASE_USER=reportes
DATABASE_PASSWORD=reportes_2026_secret

# ── Moodle DB (solo lectura, BD externa) ──────────────────────────────────────
MOODLE_DB_HOST=host.docker.internal
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=zajunadb
MOODLE_DB_USER=postgres
MOODLE_DB_PASSWORD=12345

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Seguridad ─────────────────────────────────────────────────────────────────
REPORTES_SECRET_KEY=zajuna_reportes_secure_2026_xK9mP

# ── Archivos generados ────────────────────────────────────────────────────────
REPORTES_OUTPUT_DIR=/app/reportes_generados
REPORTES_MAX_FILES_PER_USER=100
REPORTES_ROWS_PER_FILE=1000000

# ── Moodle SSO (Web Services) ─────────────────────────────────────────────────
# Acceso interno al Moodle desde el contenedor
MOODLE_URL=https://zajunavideo5.com/zajuna
MOODLE_WS_SERVICE=reportes_zajuna
# Host header debe coincidir con el wwwroot de Moodle
MOODLE_HOST_HEADER=zajunavideo5.com
# URL pública de Moodle (la que abre el browser del usuario)
MOODLE_PUBLIC_URL=https://zajunavideo5.com/zajuna

# ── Frontend (URL donde aterriza el usuario tras autologin desde Moodle) ─────
REPORTES_FRONTEND_URL=https://zajunavideo5.com/analitica
# Prefijo de ruta detrás de nginx (debe coincidir con location /analitica/)
REPORTES_BASE_PATH=/analitica

# ── CORS (orígenes permitidos, separados por coma) ───────────────────────────
REPORTES_CORS_ORIGINS=https://zajunavideo5.com
